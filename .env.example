# Copy to .env for local runs (never commit .env). On Render, set these as env vars.

# --- Vertex AI ---
GCP_PROJECT_ID=listex-ua-production
# Region travels with the model: 2.5 models are single-region only, 3.x multi-region only.
GCP_LOCATION=us-central1      # Gemini 2.5 models (single-region)
GCP_LOCATION_V3=us            # Gemini 3.x models (us/eu multi-region)
GEMINI_MODEL=gemini-2.5-flash-lite

# Service account JSON, base64-encoded (single line). Generate with:
#   base64 -i /path/to/service-account.json | tr -d '\n'
# The SA needs the "Vertex AI User" role and the Vertex AI API enabled on the project.
GCP_SA_BASE64=

# --- Access control (HTTP Basic Auth) ---
# If either is blank, the app runs WITHOUT a password (local dev only).
BASIC_AUTH_USER=
BASIC_AUTH_PASS=

# --- Server ---
PORT=3000
